# Configuracion para docker compose
NODE_ENV=production
WEB_SERVER_PORT=3000
SWAGGER_ENABLED=false

# El frontend se sirve por Nginx en :8080 y proxy /api al backend.
FRONTEND_URL=http://localhost:8080
# Opcionalmente, si quieres servir el frontend desde el backend, puedes usar la siguiente URL:
LOCAL_DIR_URL=

# Ollama nativo en el Mac host, accesible desde Docker Desktop.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_TIMEOUT_MS=180000
